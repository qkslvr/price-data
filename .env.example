# Copy to .env for LOCAL development of the API/dashboard only.
# In production these live in Vercel (API) and GitHub Actions secrets (puller).

# Neon Postgres. Use the POOLED endpoint (…-pooler…) for the API on Vercel;
# the plain endpoint is fine for the puller. sslmode=require is required.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/bestquotes?sslmode=require
